{
  "name": "robotrader-ai",
  "productName": "RoboTrader AI",
  "version": "1.0.0",
  "description": "Robô de trading com IA para Binance — paper trading com ATR stops, IA Gemini e risk engine",
  "author": "RoboTrader AI",
  "private": true,
  "sideEffects": false,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "electron:dev": "concurrently -k -n vite,electron -c blue,green \"cross-env VITE_DEV_SERVER_URL=http://localhost:5173 vite dev\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder --win --x64",
    "electron:build:portable": "npm run build && electron-builder --win portable --x64",
    "dist": "npm run build && electron-builder --win --x64"
  },
